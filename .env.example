# Template for local .env values.
# .env is ignored by git.

TPOT_HOST=203.0.113.10
TPOT_USER=remote-user
TPOT_SSH_PORT=22
TPOT_SSH_KEY=/home/your-local-user/.ssh/id_ed25519
TPOT_REMOTE_DIR=/path/to/tpotce/data
TPOT_LOCAL_DIR=data/logs_only

# Use sudo on the remote host for rsync. This requires a sudoers rule like:
# remote-user ALL=(root) NOPASSWD: /usr/bin/rsync
TPOT_USE_SUDO_RSYNC=true

# Optional Splunk HTTP Event Collector integration.
SPLUNK_HEC_URL=https://splunk.example:8088
SPLUNK_HEC_TOKEN=replace-me
SPLUNK_INDEX=honeypot
SPLUNK_SOURCE=honeypot-ai
SPLUNK_SOURCETYPE=honeypot:analysis
SPLUNK_HOST=honeypot-ai
