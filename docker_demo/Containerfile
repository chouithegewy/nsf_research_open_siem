FROM rust:1.78 as builder
# Install python and dependencies
RUN apt-get update && apt-get install -y python3 python3-pip git curl && rm -rf /var/lib/apt/lists/*
# Install Falco for sample events
RUN curl -fsSL https://download.falco.org/packages/bin/falco -o /usr/local/bin/falco && chmod +x /usr/local/bin/falco
# Copy project source
WORKDIR /app
COPY . /app
# Build eBPF sensor with live-ebpf feature (requires Linux kernel headers)
RUN apt-get update && apt-get install -y linux-headers-$(uname -r) \
    cargo build -p ebpf-sensor --features live-ebpf --release
# Install Python package in editable mode
RUN pip3 install -e src/honeypot_ai
# Final runtime image (lighter)
FROM ubuntu:22.04
RUN apt-get update && apt-get install -y python3 python3-pip curl && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app /app
WORKDIR /app
ENV PYTHONPATH=/app/src
CMD ["bash", "-c", "falco -r /etc/falco/falco_rules.yaml -E sample-events execve | python3 -m honeypot_ai live-sensor --format wazuh --model data/models/current/model.joblib --output /tmp/alerts.ndjson"]
