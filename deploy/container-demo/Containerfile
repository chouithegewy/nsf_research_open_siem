FROM docker.io/library/python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        iproute2 \
        netcat-openbsd \
        nmap \
        openssh-client \
        procps \
        sshpass \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
COPY deploy/wazuh/dashboard ./deploy/wazuh/dashboard
COPY deploy/container-demo/bin ./deploy/container-demo/bin

RUN pip install --no-cache-dir \
        -e . \
        duckdb \
        joblib \
        numpy \
        pandas \
        pyarrow \
        python-dotenv \
        river \
        scikit-learn \
    && chmod +x /app/deploy/container-demo/bin/*

CMD ["python", "-m", "honeypot_ai", "--help"]
