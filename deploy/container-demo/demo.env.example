# Copy to .env in this directory or pass with `podman compose --env-file`.

# Host ports exposed by the reverse proxy.
DEMO_DASHBOARD_PORT=8888
DEMO_SSH_PORT=2222

# Optional local/private LLM reached through the NetBird VPN from Podman.
# The dashboard renderer talks to llm-bridge inside Compose, and llm-bridge
# forwards to this upstream endpoint.
DEMO_LLM_ENABLED=true
# Default routes dashboard requests to llm-bridge. For an OpenAI-compatible
# upstream such as LM Studio, use http://llm-bridge:8080/v1 and set
# DEMO_UPSTREAM_LLM_ENDPOINT to the upstream host without /v1.
DEMO_LLM_ENDPOINT=http://llm-bridge:8080
DEMO_UPSTREAM_LLM_ENDPOINT=ip_address_of_server_hosting_llm:port
DEMO_UPSTREAM_LLM_BEARER_TOKEN=
DEMO_LLM_MODEL=qwen/qwen3.5-9b
DEMO_LLM_BEARER_TOKEN=
DEMO_LLM_TIMEOUT=240
DEMO_LLM_MAX_TOKENS=96
DEMO_LLM_DASHBOARD_TIMEOUT=300
DEMO_LLM_BRIDGE_TIMEOUT=300

# Demo loop timing.
SIEM_POLL_SECONDS=2
ML_POLL_SECONDS=5
ML_WINDOW_SECONDS=60
ML_THRESHOLD=0
RENDER_POLL_SECONDS=2

# Cowrie tag can be pinned for reproducible presentations.
COWRIE_IMAGE_TAG=latest
