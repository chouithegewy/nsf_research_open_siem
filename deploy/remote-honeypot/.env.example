# Copy to .env on the remote host and adjust before starting Docker Compose.

# Keep this on 2222 until remote administrative SSH has been moved away from
# public port 22 and verified from a second session.
COWRIE_HOST_SSH_PORT=2222

# Cowrie listens internally on 2223 when Telnet is enabled. Leave disabled
# unless Telnet is part of the experiment.
COWRIE_TELNET_ENABLED=no
COWRIE_HOST_TELNET_PORT=2223

# Use "latest" for quick iteration, or pin a tested Cowrie release tag before
# a longer data-collection run.
COWRIE_IMAGE_TAG=latest

# Sensor name appears in Cowrie events and makes multi-host collections easier.
HONEYPOT_SENSOR_NAME=cowrie-remote-01
